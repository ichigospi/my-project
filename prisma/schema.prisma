generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ===== ユーザー & 認証 =====
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String
  role           String   @default("editor") // owner, admin, editor, viewer
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invitedBy   User?   @relation("InvitedBy", fields: [invitedById], references: [id])
  invitedById String?
  invitees    User[]  @relation("InvitedBy")
  invites     Invite[]

  analyses  ScriptAnalysis[]
  proposals ScriptProposal[]
}

model Invite {
  id        String   @id @default(cuid())
  email     String
  role      String   @default("editor")
  token     String   @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String
}

model AppSetting {
  key   String @id
  value String
}

// ===== 台本分析ライブラリ =====
model ScriptAnalysis {
  id             String   @id @default(cuid())
  userId         String
  videoId        String
  videoUrl       String
  videoTitle     String
  channelName    String
  thumbnailUrl   String   @default("")
  views          Int      @default(0)
  transcript     String
  analysisResult String?  // JSON string
  category       String   @default("other")
  tags           String   @default("[]") // JSON array
  score          String?  // JSON string
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ScriptProposal {
  id                String   @id @default(cuid())
  userId            String
  sourceAnalysisIds String   @default("[]") // JSON array
  style             String   @default("healing")
  topic             String   @default("")
  proposal          String?  // JSON string
  generatedScript   String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===== ローンチツール =====
model LaunchExample {
  id        String   @id @default(cuid())
  // 種類: posts_phase1, posts_phase2, posts_phase3, columns, letter, line
  type      String
  title     String   @default("")
  content   String
  note      String   @default("") // メモ（なぜ良いのか等）
  createdAt DateTime @default(now())

  @@index([type])
}
