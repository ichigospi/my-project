generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ===== ユーザー & 認証 =====
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String
  role           String   @default("editor") // owner, admin, editor, viewer
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invitedBy   User?   @relation("InvitedBy", fields: [invitedById], references: [id])
  invitedById String?
  invitees    User[]  @relation("InvitedBy")
  invites     Invite[]

  analyses  ScriptAnalysis[]
  proposals ScriptProposal[]
}

model Invite {
  id        String   @id @default(cuid())
  email     String
  role      String   @default("editor")
  token     String   @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String
}

model AppSetting {
  key   String @id
  value String
}

// ===== 台本分析ライブラリ =====
model ScriptAnalysis {
  id             String   @id @default(cuid())
  userId         String
  videoId        String
  videoUrl       String
  videoTitle     String
  channelName    String
  thumbnailUrl   String   @default("")
  views          Int      @default(0)
  transcript     String
  analysisResult String?  // JSON string
  category       String   @default("other")
  tags           String   @default("[]") // JSON array
  score          String?  // JSON string
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ScriptProposal {
  id                String   @id @default(cuid())
  userId            String
  sourceAnalysisIds String   @default("[]") // JSON array
  style             String   @default("healing")
  topic             String   @default("")
  proposal          String?  // JSON string
  generatedScript   String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===== 売上管理 =====
model SalesRecord {
  id          String   @id @default(cuid())
  date        String   // YYYY-MM-DD
  description String   // 取引名（振込名、支払先など）
  amount      Int      // 金額（正:入金、負:出金）
  balance     Int      // 取引後の残高
  category    String   @default("other") // income, expense, transfer, other
  note        String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

// ===== ローンチツール =====
model LaunchExample {
  id        String   @id @default(cuid())
  // 種類: posts_phase1, posts_phase2, posts_phase3, columns, letter, line
  type      String
  title     String   @default("")
  content   String
  note      String   @default("") // メモ（なぜ良いのか等）
  createdAt DateTime @default(now())

  @@index([type])
}

// ===== Xポストツール =====

// 自アカ情報（ジャンルごとに1レコード）
model XAccountInfo {
  id                String   @id @default(cuid())
  genre             String   @unique // "business" | "spiritual"

  // アカウント基本
  accountName       String   @default("")
  handle            String   @default("")
  concept           String   @default("")
  target            String   @default("")
  followerImage     String   @default("")

  // ポジショニング
  usp               String   @default("")
  character         String   @default("")
  divinationStyle   String   @default("") // 占い系のみ

  // 口調
  pronoun           String   @default("")
  sentenceEnd       String   @default("")
  temperature       String   @default("")
  emojiUsage        String   @default("")
  lineBreakRule     String   @default("")

  // KW
  mainKeywords      String   @default("[]") // JSON array
  subKeywords       String   @default("[]") // JSON array
  ngExpressions     String   @default("")

  // 商品
  mainProduct       String   @default("")
  lpUrl             String   @default("")

  // 過去のストーリー（信用の教育用）
  storyBeforeState  String   @default("{}") // JSON: 状況/数字/心境
  storyTurningPoint String   @default("{}") // JSON: きっかけ/出会い/気付き
  storyEpisodes     String   @default("[]") // JSON array: 苦労エピソード
  storyExtremeActs  String   @default("[]") // JSON array: ぶっ飛び体験
  storyNgBehaviors  String   @default("[]") // JSON array: 過去のNG行動
  storyAfterState   String   @default("{}") // JSON: 状況/数字/ライフスタイル
  storyCommonGround String   @default("[]") // JSON array: 読者との共通点
  storyPhrases      String   @default("[]") // JSON array: 印象的フレーズ

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// 教材・参考ポスト・メモ（typeで区別）
model XKnowledge {
  id              String   @id @default(cuid())
  genre           String   // "business" | "spiritual" | "common"
  type            String   // "teaching" | "reference_post" | "memo"
  title           String   @default("")
  content         String

  // reference_post時のみ
  authorHandle    String   @default("")
  postUrl         String   @default("")
  likes           Int      @default(0)
  retweets        Int      @default(0)
  impressions     Int      @default(0)
  postedAt        DateTime?
  structureType   String   @default("")
  hookAnalysis    String   @default("")
  bodyAnalysis    String   @default("")
  closingAnalysis String   @default("")
  usedWords       String   @default("[]")
  applicationHint String   @default("")

  // 共通
  tags            String   @default("[]")
  source          String   @default("")
  note            String   @default("")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([genre])
  @@index([type])
}

// 競合アカウント（isSelf=true は自アナリティクス対象の自分のアカウント）
model XCompetitor {
  id        String   @id @default(cuid())
  genre     String
  handle    String
  name      String   @default("")
  note      String   @default("")
  isSelf    Boolean  @default(false)

  posts     XPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([genre, handle])
}

// 収集した競合ポスト
model XPost {
  id            String   @id @default(cuid())
  competitorId  String
  postId        String   @default("") // X側の投稿ID
  postUrl       String   @default("")
  content       String
  likes         Int      @default(0)
  retweets      Int      @default(0)
  replies       Int      @default(0)
  impressions   Int      @default(0)
  postedAt      DateTime?
  collectedAt   DateTime @default(now())

  // 引用RT検出用
  isQuoteRt     Boolean  @default(false)
  quotedPostUrl String   @default("")

  competitor    XCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
}

// ポスト分析結果
model XPostAnalysis {
  id                String   @id @default(cuid())
  genre             String
  postIds           String   @default("[]") // 分析対象ポストID JSON array
  result            String?  // JSON: 構成タイプ/フック/強化要素 等
  summary           String   @default("")
  customInstruction String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([genre])
}

// 単一ポストテンプレ
model XPostTemplate {
  id           String   @id @default(cuid())
  genre        String
  name         String
  sourceType   String   // "competitor_post" | "reference_post" | "scratch"
  sourceId     String?
  structure    String   @default("{}")
  skeleton     String
  placeholders String   @default("[]")
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([genre])
}

// シーケンスパターン（複数ポスト連鎖）
model XSequencePattern {
  id          String   @id @default(cuid())
  genre       String   @default("any") // "business" | "spiritual" | "any"
  name        String
  description String   @default("")
  pattern     String   // JSON: [{slot, educationType, structureType, skeleton, connectionType}]
  example     String   @default("")
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([genre])
}

// フォルダ（参考ポスト・競合ポスト・テンプレ・パターン共通）
model XFolder {
  id        String   @id @default(cuid())
  genre     String
  name      String
  color     String   @default("blue")

  items     XFolderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([genre])
}

model XFolderItem {
  id        String   @id @default(cuid())
  folderId  String
  itemType  String   // "reference_post" | "competitor_post" | "template" | "sequence_pattern"
  itemId    String

  folder    XFolder  @relation(fields: [folderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([folderId, itemType, itemId])
}

// 生成ポスト
model XGeneratedPost {
  id                String   @id @default(cuid())
  genre             String
  topic             String   @default("")
  instruction       String   @default("")
  educationType     String   @default("")
  logicType         String   @default("") // "課題解決型" | "欲求喚起型" | ""
  output            String
  metadata          String   @default("{}")

  // 参照
  sourceTemplateId  String?
  sourceAnalysisId  String?
  sequencePatternId String?
  dailyPlanId       String?
  slotIndex         Int?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([genre])
  @@index([createdAt])
}

// デイリープラン
model XDailyPlan {
  id        String   @id @default(cuid())
  genre     String
  date      String   // YYYY-MM-DD
  slots     String   // JSON: [{slot, educationType, theme, sequenceWith, connectionType, generatedPostId?, status}]
  notes     String   @default("")
  status    String   @default("draft") // "draft" | "in_progress" | "completed"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([genre, date])
  @@index([date])
}

// ===== Threadsポストツール（Xツールとは完全独立） =====

// 自アカウント（切替単位）。Threads APIは使わない方針のためトークン類は持たない
model ThreadsAccount {
  id        String   @id @default(cuid())
  name      String                    // 表示名
  handle    String   @unique
  // 投稿の土台（生成時に必ず注入）
  concept   String   @default("")     // コンセプト
  logic     String   @default("")     // 投稿ロジック（勝ちパターンの言語化）
  target    String   @default("")
  tone      String   @default("{}")   // 口調JSON: 一人称/語尾/絵文字/改行
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  competitors ThreadsCompetitor[]
  drafts      ThreadsPostDraft[]
}

// ノウハウ・投稿ルール（accountId=null は全アカ共通）
model ThreadsKnowledge {
  id         String   @id @default(cuid())
  accountId  String?
  type       String                        // "rule" | "knowhow" | "teaching" | "memo"
  title      String   @default("")
  content    String
  tags       String   @default("[]")
  isInjected Boolean  @default(true)       // 生成プロンプトへ自動注入するか
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([accountId, type])
}

// 競合アカウント
model ThreadsCompetitor {
  id        String   @id @default(cuid())
  accountId String                        // どの自アカのベンチマークか
  handle    String
  name      String   @default("")
  note      String   @default("")
  priority  Int      @default(0)          // 重点ベンチマーク順
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account ThreadsAccount          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  posts   ThreadsCompetitorPost[]

  @@unique([accountId, handle])
}

// 収集した競合投稿
model ThreadsCompetitorPost {
  id              String   @id @default(cuid())
  competitorId    String
  postUrl         String   @default("")
  content         String
  mediaUrls       String   @default("[]")
  likes           Int      @default(0)
  replies         Int      @default(0)
  reposts         Int      @default(0)
  quotes          Int      @default(0)
  views           Int      @default(0)      // 手動入力用（公開値は取れないため）
  followerCountAt Int      @default(0)      // 収集時の競合フォロワー数（伸び率算出用）
  postedAt        DateTime?
  collectedAt     DateTime @default(now())
  source          String   @default("manual") // "manual" | "keyword_api" | "scraper"
  // AI自動分類
  planType        String   @default("")     // 企画タイプ
  hookType        String   @default("")
  structureJson   String   @default("{}")   // フック/展開/締めの構造分解
  isHot           Boolean  @default(false)  // 伸び判定

  competitor ThreadsCompetitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@index([planType])
  @@index([isHot])
}

// フック・企画・CTAライブラリ（typeで統一管理）
model ThreadsLibraryItem {
  id           String   @id @default(cuid())
  accountId    String?                    // null=共通
  type         String                     // "hook" | "plan" | "cta"
  title        String
  content      String                     // フック文/企画骨子/CTA文
  sourcePostId String?                    // 抽出元の競合投稿
  tags         String   @default("[]")
  strength     Int      @default(3)       // 1-5 主観評価
  useCount     Int      @default(0)
  note         String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([accountId, type])
}

// 投稿管理の中核
model ThreadsPostDraft {
  id             String   @id @default(cuid())
  accountId      String
  // 参考投稿A/B（スナップショット保存: 元が消えても残す）
  refAPostId     String?
  refASnapshot   String   @default("{}")
  refBPostId     String?
  refBSnapshot   String   @default("{}")
  // 生成
  content        String   @default("")     // オマージュ投稿案（手動編集可）
  generationMeta String   @default("{}")   // 使用フック/CTA/企画、合成モード、モデル、類似度
  mediaUrls      String   @default("[]")
  // 運用（投稿の公開はスマホから手動）
  status         String   @default("draft") // draft|approved|scheduled|published|rejected
  approvedById   String?
  scheduledAt    DateTime?
  publishedAt    DateTime?
  postUrl        String   @default("")     // 手動投稿後に貼るURL（計測キー）
  // 計測（Phase 1は手動入力、Phase 2でスクレイパー自動化。viewsは常に手動）
  views          Int      @default(0)
  likes          Int      @default(0)
  replies        Int      @default(0)
  reposts        Int      @default(0)
  quotes         Int      @default(0)
  metricsUpdatedAt DateTime?
  // 振り返り
  insight        String   @default("")     // 考察
  ownerComment   String   @default("")     // オーナーコメント
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account   ThreadsAccount          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  chats     ThreadsChatMessage[]
  snapshots ThreadsMetricSnapshot[]

  @@index([accountId, status])
  @@index([scheduledAt])
}

// 壁打ちチャット（投稿案ごと）
model ThreadsChatMessage {
  id        String   @id @default(cuid())
  draftId   String
  role      String                        // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  draft ThreadsPostDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
}

// Threadsツール設定（1レコードのみ。キーはサーバー側に保管）
model ThreadsToolSettings {
  id             String   @id @default(cuid())
  apifyToken     String   @default("")     // スクレイパー（Phase 2）
  apifyActorId   String   @default("")
  openaiApiKey   String   @default("")     // 画像生成（Phase 2）
  scraperEnabled Boolean  @default(false)
  metricsTiming  String   @default("[1,24,72,168]") // 計測タイミング(時間)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// 計測の時系列スナップショット
model ThreadsMetricSnapshot {
  id         String   @id @default(cuid())
  draftId    String
  capturedAt DateTime @default(now())
  views      Int      @default(0)
  likes      Int      @default(0)
  replies    Int      @default(0)
  reposts    Int      @default(0)
  quotes     Int      @default(0)

  draft ThreadsPostDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
}

// Xポストツール設定
model XSettings {
  id              String   @id @default(cuid())
  genre           String   @unique
  postsPerDay     Int      @default(5)
  educationConfig String   @default("{}") // 各教育の最低頻度
  sequenceConfig  String   @default("{}") // パターン使用率
  spiceEnabled    Boolean  @default(true)
  defaultModel    String   @default("claude-sonnet-4-6") // 生成時のデフォルトモデル
  xApiBearerToken String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
